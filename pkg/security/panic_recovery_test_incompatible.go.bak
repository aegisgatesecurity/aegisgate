}

func TestPanicRecoveryMiddleware_PanicInNestedHandler(t *testing.T) {
	nestedHandler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		// Some processing
		_ = r.Method
		// Then panic
		panic("nested panic")
	})

	handler := PanicRecoveryMiddleware(nestedHandler)

	req := httptest.NewRequest("POST", "/api/resource", bytes.NewBufferString("data"))
	rr := httptest.NewRecorder()

	handler.ServeHTTP(rr, req)

	if rr.Code != http.StatusInternalServerError {
		t.Errorf("Status code = %d, want %d", rr.Code, http.StatusInternalServerError)
	}
}

func TestPanicRecoveryMiddleware_ContentType(t *testing.T) {
	handler := PanicRecoveryMiddleware(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		panic("trigger recovery")
	}))

	req := httptest.NewRequest("GET", "/test", nil)
	rr := httptest.NewRecorder()

	handler.ServeHTTP(rr, req)

	contentType := rr.Header().Get("Content-Type")
	if !strings.Contains(contentType, "application/json") {
		t.Errorf("Content-Type = %s, want application/json", contentType)
	}
}

func TestPanicRecoveryMiddleware_ResponseWritten(t *testing.T) {
	handler := PanicRecoveryMiddleware(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		w.WriteHeader(http.StatusOK)
		w.Write([]byte("partial response"))
		panic("after write")
	}))

	req := httptest.NewRequest("GET", "/test", nil)
	rr := httptest.NewRecorder()

	// This is a tricky case - panic after partial write
	// The behavior depends on implementation
	defer func() {
		if r := recover(); r != nil {
			t.Logf("Handler panicked as expected: %v", r)
		}
	}()

	handler.ServeHTTP(rr, req)
}

func TestPanicRecoveryMiddleware_ConcurrentPanics(t *testing.T) {
	handler := PanicRecoveryMiddleware(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		panic("concurrent panic")
	}))

	done := make(chan bool, 10)

	for i := 0; i < 10; i++ {
		go func() {
			req := httptest.NewRequest("GET", "/test", nil)
			rr := httptest.NewRecorder()
			handler.ServeHTTP(rr, req)
			done <- rr.Code == http.StatusInternalServerError
		}()
	}

	successCount := 0
	for i := 0; i < 10; i++ {
		if <-done {
			successCount++
		}
	}

	if successCount != 10 {
		t.Errorf("Concurrent panics: %d/10 handled correctly", successCount)
	}
}

func TestPanicRecoveryMiddleware_DifferentMethods(t *testing.T) {
	methods := []string{"GET", "POST", "PUT", "DELETE", "PATCH"}

	handler := PanicRecoveryMiddleware(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		panic("method panic: " + r.Method)
	}))

	for _, method := range methods {
		t.Run(method, func(t *testing.T) {
			var body *bytes.Buffer
			if method == "POST" || method == "PUT" || method == "PATCH" {
				body = bytes.NewBufferString("data")
			} else {
				body = bytes.NewBuffer(nil)
			}

			req := httptest.NewRequest(method, "/test", body)
			rr := httptest.NewRecorder()

			handler.ServeHTTP(rr, req)

			if rr.Code != http.StatusInternalServerError {
				t.Errorf("Method %s: Status code = %d, want %d", method, rr.Code, http.StatusInternalServerError)
			}
		})
	}
}

func TestPanicRecoveryMiddleware_PanicDataTypes(t *testing.T) {
	tests := []struct {
		name  string
		panic interface{}
	}{
		{"string", "panic message"},
		{"int", 42},
		{"bool", true},
		{"slice", []string{"a", "b"}},
		{"map", map[string]string{"key": "value"}},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			panicValue := tt.panic
			handler := PanicRecoveryMiddleware(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
				panic(panicValue)
			}))

			req := httptest.NewRequest("GET", "/test", nil)
			rr := httptest.NewRecorder()

			handler.ServeHTTP(rr, req)

			if rr.Code != http.StatusInternalServerError {
				t.Errorf("Status code = %d, want %d", rr.Code, http.StatusInternalServerError)
			}
		})
	}
}

func TestPanicRecoveryMiddleware_Logging(t *testing.T) {
	// If the middleware logs panics, this test verifies that
	handler := PanicRecoveryMiddleware(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		panic("log this panic")
	}))

	req := httptest.NewRequest("GET", "/test", nil)
	rr := httptest.NewRecorder()

	handler.ServeHTTP(rr, req)

	// Response should be 500 and contain error message
	if rr.Code != http.StatusInternalServerError {
		t.Errorf("Status code = %d, want %d", rr.Code, http.StatusInternalServerError)
	}

	body := rr.Body.String()
	if body == "" {
		t.Error("Response body should not be empty")
	}
}
