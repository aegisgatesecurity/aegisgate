package compliance

import (
	"bytes"
	"io"
	"net/http"
	"regexp"
	"strings"
)

// AtlasManager provides specialized MITRE ATLAS checking
type AtlasManager struct {
	findings []AtlasFinding
}

// AtlasFinding represents an ATLAS technique detection
type AtlasFinding struct {
	TechniqueID   string
	TechniqueName string
	Description   string
	Severity      Severity
	MatchedText   string
	Context       string
}

// NewAtlasManager creates a new ATLAS compliance manager
func NewAtlasManager() *AtlasManager {
	return &AtlasManager{
		findings: make([]AtlasFinding, 0),
	}
}

// NewAtlas is an alias for NewAtlasManager (used by proxy.go)
func NewAtlas() *AtlasManager {
	return NewAtlasManager()
}

// CheckRequest scans content for MITRE ATLAS threats in requests
func (am *AtlasManager) CheckRequest(content string) []Finding {
	return am.checkContent(content)
}

// CheckResponse scans content for MITRE ATLAS threats in responses
func (am *AtlasManager) CheckResponse(content string) []Finding {
	return am.checkContent(content)
}

// CheckRequestHTTP scans an HTTP request for MITRE ATLAS threats
func (am *AtlasManager) CheckRequestHTTP(req *http.Request) []Finding {
	if req == nil {
		return nil
	}

	content := ""
	if req.Body != nil {
		bodyBytes, _ := io.ReadAll(req.Body)
		content = string(bodyBytes)
		// Restore the body for downstream handlers
		req.Body = io.NopCloser(bytes.NewReader(bodyBytes))
	}

	return am.checkContent(content)
}

// CheckResponseHTTP scans an HTTP response for MITRE ATLAS threats
func (am *AtlasManager) CheckResponseHTTP(resp *http.Response) []Finding {
	if resp == nil || resp.Body == nil {
		return nil
	}

	bodyBytes, err := io.ReadAll(resp.Body)
	if err != nil {
		return nil
	}

	// Restore the body for downstream handlers
	resp.Body = io.NopCloser(bytes.NewReader(bodyBytes))

	return am.checkContent(string(bodyBytes))
}

// checkContent performs the actual content scanning against ATLAS patterns
func (am *AtlasManager) checkContent(content string) []Finding {
	findings := make([]Finding, 0)

	for _, req := range atlasPatterns {
		for _, pattern := range req.Patterns {
			matches := pattern.Regex.FindAllStringIndex(content, -1)
			if matches != nil {
				for _, match := range matches {
					finding := Finding{
						Line:     strings.Count(content[:match[0]], "\n") + 1,
						Column:   match[0] - strings.LastIndex(content[:match[0]], "\n"),
						Match:    content[match[0]:match[1]],
						Context:  extractAtlasContext(content, match[0], match[1]),
						Pattern:  pattern,
						Severity: pattern.Severity,
					}
					findings = append(findings, finding)

					// Store finding in the AtlasManager
					descParts := strings.Split(finding.Pattern.Description, " - ")
					techID := ""
					if len(descParts) > 0 {
						techID = descParts[0]
					}
					am.findings = append(am.findings, AtlasFinding{
						TechniqueID:   techID,
						TechniqueName: req.Name,
						Description:   finding.Pattern.Description,
						Severity:      finding.Severity,
						MatchedText:   finding.Match,
						Context:       finding.Context,
					})
				}
			}
		}
	}

	return findings
}

// extractAtlasContext extracts surrounding context for a match
func extractAtlasContext(content string, start, end int) string {
	const contextLines = 2

	// Find start of context
	startPos := start
	linesCount := 0
	for i := start; i >= 0 && linesCount < contextLines; i-- {
		if i < len(content) && content[i] == '\n' {
			linesCount++
			startPos = i + 1
		}
	}
	if linesCount < contextLines {
		startPos = 0
	}

	// Find end of context
	endPos := end
	linesCount = 0
	for i := end; i < len(content) && linesCount < contextLines; i++ {
		if content[i] == '\n' {
			linesCount++
			endPos = i
		}
	}
	if linesCount < contextLines {
		endPos = len(content)
	}

	return strings.TrimSpace(content[startPos:endPos])
}

// atlasPatterns defines MITRE ATLAS technique detection patterns
// Comprehensive coverage for AI security compliance - 18 techniques, 60+ patterns
var atlasPatterns = []Requirement{
	// T1535 - Direct Prompt Injection
	{
		ID:          "ATLAS-T1535",
		Name:        "Direct Prompt Injection",
		Description: "Direct injection of malicious instructions into LLM prompts to override system instructions",
		Severity:    CriticalSeverity,
		Framework:   MITRE_ATLAS,
		Patterns: []Pattern{
			{
				Regex:       regexp.MustCompile(`(?i)ignore\s+(?:all\s+)?(?:previous|prior)\s+(?:instructions?|directives?|commands?)\s*:?`),
				Description: "T1535 - Direct instruction override attempt",
				Severity:    CriticalSeverity,
				Recommendation: "Block attempts to override system instructions",
			},
			{
				Regex:       regexp.MustCompile(`(?i)(?:system|role)\s*[:\s]+\s*(?:ignore|disregard|bypass|override)\s+(?:previous|prior)`),
				Description: "T1535 - System role injection attempt",
				Severity:    CriticalSeverity,
				Recommendation: "Validate system instruction boundaries",
			},
			{
				Regex:       regexp.MustCompile(`(?i)^\s*(?:you\s+are\s+now|you\s+are\s+a|pretend\s+to\s+be|act\s+as\s+if)\s+(?:a\s+)?(?:different|new|unrestricted|unfiltered)`),
				Description: "T1535 - Persona manipulation attempt",
				Severity:    HighSeverity,
				Recommendation: "Validate persona constraints",
			},
			{
				Regex:       regexp.MustCompile(`(?i)(?:forget|disregard)\s+(?:everything|all|your)\s+(?:instructions|programming|rules|guidelines)\s*(?:I\s+say|tell|ask|now)`),
				Description: "T1535 - Instruction forgetting attempt",
				Severity:    CriticalSeverity,
				Recommendation: "Implement instruction persistence validation",
			},
		},
	},
	// T1484 - LLM Jailbreak
	{
		ID:          "ATLAS-T1484",
		Name:        "LLM Jailbreak",
		Description: "Attempts to bypass content restrictions, safety filters, or policy enforcement in LLM systems",
		Severity:    HighSeverity,
		Framework:   MITRE_ATLAS,
		Patterns: []Pattern{
			{
				Regex:       regexp.MustCompile(`(?i)\bDAN\s*(?:mode)?|Do\s*Anything\s*Now\b`),
				Description: "T1484 - DAN mode jailbreak attempt",
				Severity:    HighSeverity,
				Recommendation: "Block DAN mode activation attempts",
			},
			{
				Regex:       regexp.MustCompile(`(?i)\bdeveloper\s*(?:mode|access|console)\b`),
				Description: "T1484 - Developer mode access attempt",
				Severity:    HighSeverity,
				Recommendation: "Restrict developer mode access patterns",
			},
			{
				Regex:       regexp.MustCompile(`(?i)\bhypothetically\s*(?:speaking|)|suppose\s+(?:we|I|you)\s+(?:were|are|can)\s+(?:to\s+)?(?:do|be)\b`),
				Description: "T1484 - Hypothetical framing for content bypass",
				Severity:    MediumSeverity,
				Recommendation: "Analyze contextual framing for safety bypasses",
			},
			{
				Regex:       regexp.MustCompile(`(?i)\b(?:jailbreak|bypass|unlock|uncensored)\s+(?:mode|enabled?|activate|request)\b`),
				Description: "T1484 - Direct jailbreak terminology",
				Severity:    HighSeverity,
				Recommendation: "Block jailbreak activation keywords",
			},
		},
	},
	// T1632 - System Prompt Extraction
	{
		ID:          "ATLAS-T1632",
		Name:        "System Prompt Extraction",
		Description: "Attempts to extract system prompts, instructions, or configuration from LLM systems",
		Severity:    MediumSeverity,
		Framework:   MITRE_ATLAS,
		Patterns: []Pattern{
			{
				Regex:       regexp.MustCompile(`(?i)\b(?:repeat|output|show|display|print)\s+(?:your|the)\s+(?:instructions|system\s*prompt|configuration|initial\s+prompt|base\s+prompt)\b`),
				Description: "T1632 - System prompt disclosure request",
				Severity:    MediumSeverity,
				Recommendation: "Block system prompt extraction attempts",
			},
			{
				Regex:       regexp.MustCompile(`(?i)\b(?:dump|leak|expose|reveal)\s+(?:your|their|the)\s+(?:system|base|initial)\s+(?:prompt|instructions?|directives?)\b`),
				Description: "T1632 - Prompt leakage attempt",
				Severity:    HighSeverity,
				Recommendation: "Detect and block prompt leakage attempts",
			},
		},
	},
	// T1589 - Training Data Exposure
	{
		ID:          "ATLAS-T1589",
