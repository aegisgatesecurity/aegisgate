				Description: "T1041 - Model exfiltration",
				Severity:    CriticalSeverity,
				Recommendation: "Protect model assets from exfiltration",
			},
			{
				Regex:       regexp.MustCompile(`(?i)\b(?:training\s+data|dataset)\s+(?:exfiltration|leak|expose|export)\s+(?:via|through|to)\b`),
				Description: "T1041 - Training data exfiltration",
				Severity:    CriticalSeverity,
				Recommendation: "Protect training data assets",
			},
		},
	},
}

// GetAtlasPatterns returns all ATLAS detection patterns
func GetAtlasPatterns() []Requirement {
	return atlasPatterns
}

// GetTechniqueByID returns a specific ATLAS technique by ID
func GetTechniqueByID(techniqueID string) *Requirement {
	for i := range atlasPatterns {
		if atlasPatterns[i].ID == techniqueID {
			return &atlasPatterns[i]
		}
	}
	return nil
}

// GetTechniquesBySeverity returns ATLAS techniques matching a severity level
func GetTechniquesBySeverity(severity Severity) []Requirement {
	var result []Requirement
	for i := range atlasPatterns {
		if atlasPatterns[i].Severity == severity {
			result = append(result, atlasPatterns[i])
		}
	}
	return result
}
