# Developer Environment Configuration
# This file contains the default settings for the Developer tier
# Ideal for freelancers, startups building MVPs, and individual developers
# Copy to .env and customize as needed

# =============================================================================
# TIER CONFIGURATION
# =============================================================================
# Set to 'community', 'developer', 'professional', or 'enterprise'
AEGISGATE_TIER=developer

# =============================================================================
# DEVELOPER TIER - PRODUCTION-READY LIMITS
# =============================================================================

# RATE LIMITS (1,000/min - Production-ready for small apps)
MAX_REQUESTS_PER_MINUTE=1000
MAX_CONCURRENT_CONNECTIONS=25
MAX_BURST_REQUESTS=200

# Resource Limits
MAX_USERS=10
MAX_API_KEYS=10
MAX_TENANTS=1

# Storage Limits
LOG_RETENTION_DAYS=7
MAX_LOG_SIZE_MB=1024
DATA_RETENTION_DAYS=30

# Feature Limits
MAX_CUSTOM_RULES=5
MAX_WEBHOOKS=10
MAX_CUSTOM_DOMAINS=0

# =============================================================================
# AI PROVIDERS - DEVELOPER
# =============================================================================
AI_PROVIDER_ENABLED=openai,anthropic,cohere,azure_openai

# Advanced AI Features
AI_REQUEST_CACHING=true
AI_REQUEST_DEDUP=true
AI_CONNECTION_POOL_SIZE=20

# =============================================================================
# SECURITY - DEVELOPER
# =============================================================================
TLS_ENABLED=true
TLS_PORT=8443
HTTP_PORT=8080
MTLS_ENABLED=true
RUNTIME_HARDENING=true
JWT_VALIDATION=true

# SSO (Basic)
OIDC_ENABLED=true
OAUTH_PROVIDERS=google,github

# =============================================================================
# LOGGING - DEVELOPER
# =============================================================================
LOG_LEVEL=info
LOG_RETENTION_DAYS=7

# =============================================================================
# METRICS - DEVELOPER
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_SCRAPE_INTERVAL=30s

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_PORT=3000

# Integrations
GRAFANA_ENABLED=true
GRAFANA_URL=https://grafana.yourcompany.com
GRAFANA_API_KEY=your-grafana-api-key

AWS_CLOUDWATCH_ENABLED=true
AWS_REGION=us-east-1

# =============================================================================
# COMPLIANCE - DEVELOPER
# =============================================================================
COMPLIANCE_ENABLED=true
COMPLIANCE_FRAMEWORKS=owasp

# Developer can view but not enforce
COMPLIANCE_STRICT_MODE=false
CUSTOM_RULE_LIMIT=5

# =============================================================================
# ML & ANOMALY DETECTION - DEVELOPER
# =============================================================================
ML_ANOMALY_DETECTION=true
ML_COST_ANOMALY_ALERTS=true
ML_USAGE_ANOMALY_ALERTS=true
ML_MODEL_PATH=/var/lib/aegisgate/models

# =============================================================================
# MULTI-TENANCY - DEVELOPER (Single tenant)
# =============================================================================
MULTI_TENANT_ENABLED=false
RBAC_ENABLED=true
GRANULAR_PERMISSIONS=true
CUSTOM_ROLES_ENABLED=true

# =============================================================================
# STORAGE - DEVELOPER (PostgreSQL recommended)
# =============================================================================
STORAGE_MODE=postgres
DATABASE_URL=postgres://user:pass@localhost:5432/aegisgate?sslmode=require
DATABASE_POOL_SIZE=10
DATABASE_MAX_CONNECTIONS=50

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# =============================================================================
# API - DEVELOPER
# =============================================================================
REST_API_ENABLED=true
GRPC_API_ENABLED=true
GRPC_PORT=9001
WEBHOOKS_ENABLED=true

TERRAFORM_PROVIDER_ENABLED=true

# =============================================================================
# DEPLOYMENT - DEVELOPER
# =============================================================================
DEPLOY_DOCKER=true
DEPLOY_TERRAFORM=true

# =============================================================================
# SUPPORT - DEVELOPER
# =============================================================================
SUPPORT_LEVEL=email
SUPPORT_EMAIL=support@aegisgatesecurity.ioyourcompany.com
SUPPORT_RESPONSE_TIME=48h
