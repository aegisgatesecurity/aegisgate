# Professional Environment Configuration
# This file contains the default settings for the Professional tier
# Requires valid Professional license key
# Copy to .env and customize as needed

# =============================================================================
# TIER CONFIGURATION
# =============================================================================
# Set to 'community', 'professional', or 'enterprise'
AEGISGATE_TIER=professional

# =============================================================================
# PROFESSIONAL TIER - REQUIRES LICENSE KEY
# =============================================================================
# Your Professional license key
AEGISGATE_LICENSE_KEY=pro-xxxxxxxxxxxxxxxxxxxxx

# License validation server (self-hosted for Professional)
LICENSE_SERVER_URL=https://license.yourcompany.com
LICENSE_VALIDATION_INTERVAL=24h

# =============================================================================
# AI PROVIDERS - PROFESSIONAL
# =============================================================================
AI_PROVIDER_ENABLED=openai,anthropic,cohere,azure_openai,aws_bedrock

# Advanced AI Features
AI_REQUEST_CACHING=true
AI_REQUEST_DEDUP=true
AI_BATCH_PROCESSING=true
AI_CONNECTION_POOL_SIZE=50

# =============================================================================
# SECURITY - PROFESSIONAL
# =============================================================================
TLS_ENABLED=true
TLS_PORT=8443
HTTP_PORT=8080

# Advanced Security Features
MTLS_ENABLED=true
PKI_ATTESTATION_ENABLED=true
SECRET_ROTATION_ENABLED=true
SECRET_ROTATION_INTERVAL=24h

# SSO/SAML
SAML_ENABLED=true
OIDC_ENABLED=true
OAUTH_PROVIDERS=okta,azure_ad,google_workspace

# Audit
AUDIT_LOG_ENCRYPTION=true
AUDIT_RETENTION_DAYS=90

# =============================================================================
# COMPLIANCE - PROFESSIONAL
# =============================================================================
COMPLIANCE_ENABLED=true
COMPLIANCE_FRAMEWORKS=owasp,soc2,gdpr,hipaa,pci,nist,iso27001

# Compliance Enforcement
COMPLIANCE_STRICT_MODE=true
COMPLIANCE_AUTO_REMEDIATE=true

# Custom Frameworks
CUSTOM_FRAMEWORK_ENABLED=true

# =============================================================================
# ML & ANOMALY DETECTION - PROFESSIONAL
# =============================================================================
ML_ANOMALY_DETECTION=true
ML_COST_ANOMALY_ALERTS=true
ML_USAGE_ANOMALY_ALERTS=true
ML_BEHAVIORAL_ANALYSIS=true
ML_PREDICTIVE_COST=true
ML_THREAT_DETECTION=true

# ML Model Configuration
ML_MODEL_PATH=/var/lib/aegisgate/models
ML_UPDATE_INTERVAL=24h

# =============================================================================
# MULTI-TENANCY - PROFESSIONAL
# =============================================================================
MULTI_TENANT_ENABLED=true
MAX_TENANTS=25
MAX_USERS_PER_TENANT=25

# RBAC
RBAC_ENABLED=true
GRANULAR_PERMISSIONS=true
CUSTOM_ROLES_ENABLED=true
POLICY_ENGINE_ENABLED=true

# =============================================================================
# OBSERVABILITY - PROFESSIONAL
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_SCRAPE_INTERVAL=15s

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_PORT=3000

# Integrations
GRAFANA_ENABLED=true
GRAFANA_URL=https://grafana.yourcompany.com
GRAFANA_API_KEY=your-grafana-api-key

DATADOG_ENABLED=true
DATADOG_API_KEY=your-datadog-api-key
DATADOG_SITE=datadoghq.com

NEWRELIC_ENABLED=true
NEWRELIC_LICENSE_KEY=your-newrelic-key

# SIEM
SIEM_ENABLED=true
SIEM_ENDPOINT=https://siem.yourcompany.com
SIEM_PROTOCOL=https
SIEM_PORT=443

# Webhooks
WEBHOOK_ENABLED=true
MAX_WEBHOOKS=10

# =============================================================================
# STORAGE - PROFESSIONAL
# =============================================================================
STORAGE_MODE=postgres
DATABASE_URL=postgres://user:pass@localhost:5432/aegisgate?sslmode=require
DATABASE_POOL_SIZE=20
DATABASE_MAX_CONNECTIONS=100

REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# =============================================================================
# API - PROFESSIONAL
# =============================================================================
REST_API_ENABLED=true
GRPC_API_ENABLED=true
GRPC_PORT=9001

TERRAFORM_PROVIDER_ENABLED=true
KUBERNETES_OPERATOR_ENABLED=true
HELM_CHART_REPO=https://charts.yourcompany.com

SDK_ENABLED=true
SDK_LANGUAGES=go,python,javascript

# =============================================================================
# DEPLOYMENT - PROFESSIONAL
# =============================================================================
DEPLOY_DOCKER=true
DEPLOY_KUBERNETES=true
DEPLOY_TERRAFORM=true
DEPLOY_HELM=true
DEPLOY_ANSIBLE=true

# Kubernetes
KUBERNETES_NAMESPACE=aegisgate
KUBERNETES_INGRESS_CLASS=nginx

# =============================================================================
# SUPPORT - PROFESSIONAL
# =============================================================================
SUPPORT_LEVEL=email
SUPPORT_EMAIL=support@aegisgatesecurity.ioyourcompany.com

# =============================================================================
# LIMITS - PROFESSIONAL
# =============================================================================
MAX_CONCURRENT_REQUESTS=100
MAX_REQUESTS_PER_MINUTE=1000
MAX_REQUEST_SIZE_MB=100
MAX_RESPONSE_SIZE_MB=500

# =============================================================================
# MONITORING - PROFESSIONAL
# =============================================================================
HEALTH_CHECK_INTERVAL=30s
METRICS_EXPORT_INTERVAL=60s

# Alerts
ALERT_WEBHOOK_URL=https://alerts.yourcompany.com/webhook
ALERT_EMAIL=alerts@yourcompany.com

# =============================================================================
# BACKUP & RECOVERY - PROFESSIONAL
# =============================================================================
BACKUP_ENABLED=true
BACKUP_INTERVAL=24h
BACKUP_RETENTION=30d
BACKUP_LOCATION=s3://your-bucket/backups

# =============================================================================
# RATE LIMITS - PROFESSIONAL
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=1000
