# Community Environment Configuration
# This file contains the default settings for the Community tier
# GENEROUS LIMITS - Designed for GROWTH and ADOPTION
# Copy to .env and customize as needed

# =============================================================================
# TIER CONFIGURATION
# =============================================================================
# Set to 'community', 'developer', 'professional', or 'enterprise'
AEGISGATE_TIER=community

# =============================================================================
# COMMUNITY TIER - GENEROUS LIMITS FOR ADOPTION
# =============================================================================

# RATE LIMITS (200/min - Enough for real testing)
MAX_REQUESTS_PER_MINUTE=200
MAX_CONCURRENT_CONNECTIONS=5
MAX_BURST_REQUESTS=50

# Resource Limits
MAX_USERS=3
MAX_API_KEYS=3
MAX_TENANTS=1

# Storage Limits
LOG_RETENTION_DAYS=1
MAX_LOG_SIZE_MB=100
DATA_RETENTION_DAYS=7

# Feature Limits
MAX_CUSTOM_RULES=0
MAX_WEBHOOKS=3
MAX_CUSTOM_DOMAINS=0

# =============================================================================
# AI PROVIDERS - COMMUNITY (Open Source Friendly)
# =============================================================================
AI_PROVIDER_ENABLED=openai,anthropic

# Basic AI Features
AI_STREAMING=true
AI_TIMEOUT_SECONDS=30

# =============================================================================
# SECURITY - COMMUNITY
# =============================================================================
TLS_ENABLED=true
TLS_PORT=8443
HTTP_PORT=8080
JWT_VALIDATION=true

# =============================================================================
# LOGGING - COMMUNITY
# =============================================================================
LOG_LEVEL=info
LOG_RETENTION_DAYS=1

# =============================================================================
# METRICS - COMMUNITY
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090

# =============================================================================
# COMPLIANCE - COMMUNITY (View Only)
# =============================================================================
COM
COMPLIANCE_FRAMEWORKS=owasp
COMPLIANCE_STRICT_MODEPLIANCE_ENABLED=true=false

# =============================================================================
# STORAGE - COMMUNITY
# =============================================================================
STORAGE_MODE=file
DATA_DIR=./data

# =============================================================================
# DEPLOYMENT - COMMUNITY
# =============================================================================
DEPLOY_DOCKER=true
DEPLOY_COMPOSE=true

# =============================================================================
# SUPPORT - COMMUNITY
# =============================================================================
SUPPORT_LEVEL=community

# =============================================================================
# ADMIN - COMMUNITY
# =============================================================================
ADMIN_DASHBOARD=true
ADMIN_ADVANCED=false
