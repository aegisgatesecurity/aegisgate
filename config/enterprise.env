# Enterprise Environment Configuration
# This file contains the default settings for the Enterprise tier
# Requires valid Enterprise license key and contract
# Contact sales for configuration assistance

# =============================================================================
# TIER CONFIGURATION
# =============================================================================
# Set to 'community', 'professional', or 'enterprise'
AEGISGATE_TIER=enterprise

# =============================================================================
# ENTERPRISE TIER - REQUIRES ENTERPRISE LICENSE
# =============================================================================
# Your Enterprise license key
AEGISGATE_LICENSE_KEY=ent-xxxxxxxxxxxxxxxxxxxxx

# Enterprise license validation (hosted by AegisGate Inc.)
LICENSE_SERVER_URL=https://license.aegisgatesecurity.io
LICENSE_VALIDATION_INTERVAL=1h

# Enterprise-specific settings
ENTERPRISE_MODE=true
CUSTOM_BRANDING=true
WHITE_LABEL_ENABLED=true

# =============================================================================
# AI PROVIDERS - ENTERPRISE (ALL)
# =============================================================================
AI_PROVIDER_ENABLED=openai,anthropic,cohere,azure_openai,aws_bedrock,google_vertex,custom

# Internal AI Tool Support
INTERNAL_AI_TOOL_ENABLED=true
INTERNAL_AI_TOOLS=cline,custom,internal

# Advanced AI Features
AI_REQUEST_CACHING=true
AI_REQUEST_DEDUP=true
AI_BATCH_PROCESSING=true
AI_CONNECTION_POOL_SIZE=500
AI_STREAMING=true

# =============================================================================
# SECURITY - ENTERPRISE (FULL)
# =============================================================================
TLS_ENABLED=true
TLS_PORT=8443
HTTP_PORT=8080

# Advanced Security
MTLS_ENABLED=true
MTLS_STRICT=true
PKI_ATTESTATION_ENABLED=true
PKI_CA_PATH=/etc/aegisgate/pki/ca.pem
SECRET_ROTATION_ENABLED=true
SECRET_ROTATION_INTERVAL=1h
RUNTIME_HARDENING_ENABLED=true

# Enterprise Identity
SAML_ENABLED=true
SAML_IDP_METADATA_URL=https://idp.yourcompany.com/metadata
OIDC_ENABLED=true
OAUTH_PROVIDERS=okta,azure_ad,google_workspace,ping_identity,forgerock

# Enterprise Directory
LDAP_ENABLED=true
LDAP_SERVER=ldap://ldap.yourcompany.com:389
LDAP_BASE_DN=dc=yourcompany,dc=com
LDAP_USER_DN=cn=users
LDAP_GROUP_DN=cn=groups

# Hardware Security
HARDWARE_TOKEN_ENABLED=true
HSM_ENABLED=true
HSM_TYPE=aws_cloudhsm,azure_keyvault,hashicorp_vault
HSM_CONFIG_PATH=/etc/aegisgate/hsm/config.json

# FIPS
FIPS_ENABLED=true
FIPS_MODE=140-2

# Audit
AUDIT_LOG_ENCRYPTION=true
AUDIT_RETENTION_DAYS=unlimited
AUDIT_COMPLIANCE_EXPORT=true
AUDIT_COMPLIANCE_FORMATS=soc2,hipaa,pcidss,iso27001

# =============================================================================
# COMPLIANCE - ENTERPRISE (ALL FRAMEWORKS)
# =============================================================================
COMPLIANCE_ENABLED=true
COMPLIANCE_FRAMEWORKS=owasp,soc2,gdpr,hipaa,pci,nist,iso27001,iso42001,nist_ai_rmf,hitrust,fedramp,atlas,cobit,nist_csf,glba,sox

# Compliance Enforcement
COMPLIANCE_STRICT_MODE=true
COMPLIANCE_AUTO_REMEDIATE=true
COMPLIANCE_QUARANTINE=true

# Custom Frameworks
CUSTOM_FRAMEWORK_ENABLED=true
CUSTOM_FRAMEWORK_API_ENABLED=true

# =============================================================================
# ML & ANOMALY DETECTION - ENTERPRISE (FULL)
# =============================================================================
ML_ANOMALY_DETECTION=true
ML_COST_ANOMALY_ALERTS=true
ML_USAGE_ANOMALY_ALERTS=true
ML_BEHAVIORAL_ANALYSIS=true
ML_PREDICTIVE_COST=true
ML_THREAT_DETECTION=true
ML_CUSTOM_MODELS=true
ML_REALTIME_RESPONSE=true
ML_ZERODAY_DETECTION=true

# ML Model Configuration
ML_MODEL_PATH=/var/lib/aegisgate/models
ML_MODEL_UPDATE_INTERVAL=1h
ML_CUSTOM_MODEL_PATH=/var/lib/aegisgate/custom-models

# =============================================================================
# MULTI-TENANCY - ENTERPRISE (FULL)
# =============================================================================
MULTI_TENANT_ENABLED=true
MAX_TENANTS=unlimited
MAX_USERS_PER_TENANT=unlimited

# Advanced RBAC
RBAC_ENABLED=true
GRANULAR_PERMISSIONS=true
CUSTOM_ROLES_ENABLED=true
POLICY_ENGINE_ENABLED=true
CROSS_TENANT_ANALYTICS=true

# Enterprise Features
WHITE_LABEL_ENABLED=true
CUSTOM_DOMAIN_ENABLED=true
CUSTOM_DOMAIN=customer.yourcompany.com

# =============================================================================
# OBSERVABILITY - ENTERPRISE (FULL)
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_SCRAPE_INTERVAL=10s

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_PORT=3000
DASHBOARD_THEMING=true

# All Integrations
GRAFANA_ENABLED=true
GRAFANA_URL=https://grafana.yourcompany.com
GRAFANA_API_KEY=your-grafana-api-key

DATADOG_ENABLED=true
DATADOG_API_KEY=your-datadog-api-key

NEWRELIC_ENABLED=true
NEWRELIC_LICENSE_KEY=your-newrelic-key

# SIEM (All)
SIEM_ENABLED=true
SIEM_ENDPOINT=https://siem.yourcompany.com
SIEM_PROTOCOL=https
SIEM_PORT=443
SPLUNK_ENABLED=true
SPLUNK_ENDPOINT=https://splunk.yourcompany.com:8088
ELASTIC_ENABLED=true
ELASTIC_URL=https://elasticsearch.yourcompany.com:9200

# Enterprise SIEM
QRADAR_ENABLED=true
QRADAR_SERVER=qradar.yourcompany.com
AZURE_SENTINEL_ENABLED=true
AZURE_SENTINEL_WORKSPACE=your-workspace-id

# AWS
AWS_CLOUDWATCH_ENABLED=true

# Webhooks
WEBHOOK_ENABLED=true
MAX_WEBHOOKS=unlimited
WEBHOOK_RETRY_COUNT=5
WEBHOOK_TIMEOUT=30s

# =============================================================================
# STORAGE - ENTERPRISE (FULL)
# =============================================================================
STORAGE_MODE=postgres
DATABASE_URL=postgres://user:pass@postgres.yourcompany.com:5432/aegisgate?sslmode=require
DATABASE_POOL_SIZE=100
DATABASE_MAX_CONNECTIONS=500
DATABASE_READ_REPLICA_URL=postgres://user:pass@postgres-ro.yourcompany.com:5432/aegisgate

REDIS_ENABLED=true
REDIS_URL=redis://redis.yourcompany.com:6379
REDIS_PASSWORD=your-redis-password
REDIS_CLUSTER_MODE=true
REDIS_SENTINEL=true

MONGODB_ENABLED=true
MONGODB_URI=mongodb://mongo.yourcompany.com:27017

S3_ENABLED=true
S3_BUCKET=aegisgate-enterprise
S3_REGION=us-east-1
S3_ENDPOINT=https://s3.yourcompany.com

# Data
DATA_ENCRYPTION_AT_REST=true
DATA_RETENTION_POLICIES=true
GDPR_DATA_DELETION=true
DATA_EXPORT_FORMATS=json,csv,parquet

# =============================================================================
# API - ENTERPRISE (FULL)
# =============================================================================
REST_API_ENABLED=true
GRPC_API_ENABLED=true
GRPC_PORT=9001
GRAPHQL_ENABLED=true
GRAPHQL_ENDPOINT=/graphql

TERRAFORM_PROVIDER_ENABLED=true
KUBERNETES_OPERATOR_ENABLED=true
HELM_CHART_REPO=https://charts.yourcompany.com
ANSIBLE_ENABLED=true

SDK_ENABLED=true
SDK_LANGUAGES=go,python,javascript,java,ruby,csharp
SDK_REGENERATE_ON_UPDATE=true

BROWSER_EXTENSION_ENABLED=true
CLI_FULL=true

# =============================================================================
# DEPLOYMENT - ENTERPRISE (FULL)
# =============================================================================
DEPLOY_DOCKER=true
DEPLOY_KUBERNETES=true
DEPLOY_TERRAFORM=true
DEPLOY_HELM=true
DEPLOY_ANSIBLE=true
DEPLOY_SERVICE_MESH=true
DEPLOY_AUTOSCALE=true
DEPLOY_HA=true
DEPLOY_MULTIREGION=true

# Kubernetes
KUBERNETES_NAMESPACE=aegisgate
KUBERNETES_INGRESS_CLASS=nginx
KUBERNETES_HPA=true
KUBERNETES_HPA_MIN_REPLICAS=2
KUBERNETES_HPA_MAX_REPLICAS=50

# Service Mesh
SERVICE_MESH_ENABLED=true
SERVICE_MESH_TYPE=istio

# Multi-region
MULTI_REGION_ENABLED=true
MULTI_REGION_REGIONS=us-east-1,us-west-2,eu-west-1,ap-southeast-1
MULTI_REGION_FAILOVER=true

# On-Premise
ON_PREMISE_ENABLED=true
AIR_GAPPED_INSTALLATION=true

# =============================================================================
# SUPPORT - ENTERPRISE (DEDICATED)
# =============================================================================
SUPPORT_LEVEL=24x7_dedicated
SUPPORT_DEDICATED_AGENT=true
SUPPORT_PHONE=true
SUPPORT_SLACK_CHANNEL=aegisgate-enterprise
SUPPORT_RESPONSE_TIME=1h
SUPPORT_SLA=99.99
SUPPORT_ONBOARDING=true
SUPPORT_TRAINING=true
SUPPORT_CUSTOM_DEVELOPMENT=true

# =============================================================================
# LIMITS - ENTERPRISE (UNLIMITED)
# =============================================================================
MAX_CONCURRENT_REQUESTS=unlimited
MAX_REQUESTS_PER_MINUTE=unlimited
MAX_REQUEST_SIZE_MB=unlimited
MAX_RESPONSE_SIZE_MB=unlimited

# =============================================================================
# BACKUP & RECOVERY - ENTERPRISE
# =============================================================================
BACKUP_ENABLED=true
BACKUP_INTERVAL=1h
BACKUP_RETENTION=unlimited
BACKUP_LOCATION=s3://your-bucket/backups
BACKUP_ENCRYPTION=true
BACKUP_GEO_REPLICATION=true

# Disaster Recovery
DR_ENABLED=true
DR_REGION=us-west-2
DR_FAILOVER_AUTOMATIC=true
DR_RPO=5m
DR_RTO=15m

# =============================================================================
# COMPLIANCE EXPORT - ENTERPRISE
# =============================================================================
COMPLIANCE_EXPORT_ENABLED=true
COMPLIANCE_REPORT_SCHEDULE=weekly
COMPLIANCE_REPORT_RECIPIENTS=compliance@yourcompany.com
