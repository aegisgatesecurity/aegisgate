# AegisGate Environment Variables Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# =============================================================================
# TIER CONFIGURATION
# =============================================================================
# Set to: community, developer, professional, enterprise
AEGISGATE_TIER=community

# License key for paid tiers (not required for community)
# AEGISGATE_LICENSE_KEY=your-license-key-here

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
AEGISGATE_HTTP_PORT=8080
AEGISGATE_HTTPS_PORT=8443
AEGISGATE_HOST=0.0.0.0
AEGISGATE_BASE_URL=/

# =============================================================================
# SECURITY
# =============================================================================
# Generate a secure random string for production!
AEGISGATE_JWT_SECRET=change-this-to-a-secure-random-string
AEGISGATE_TLS_ENABLED=false
# AEGISGATE_TLS_CERT=/path/to/cert.pem
# AEGISGATE_TLS_KEY=/path/to/key.pem
AEGISGATE_API_KEYS_ENABLED=true

# =============================================================================
# RATE LIMITING
# =============================================================================
AEGISGATE_RATE_LIMIT_ENABLED=true
AEGISGATE_RATE_LIMIT_REQUESTS=200
AEGISGATE_RATE_LIMIT_BURST=50

# =============================================================================
# LOGGING
# =============================================================================
AEGISGATE_LOG_LEVEL=info
AEGISGATE_LOG_FORMAT=json

# =============================================================================
# METRICS
# =============================================================================
AEGISGATE_METRICS_ENABLED=true
AEGISGATE_METRICS_PORT=9090

# =============================================================================
# STORAGE
# =============================================================================
# Options: file, postgres, mysql
AEGISGATE_STORAGE_MODE=file
AEGISGATE_DATA_DIR=./data

# For PostgreSQL (Developer/Professional/Enterprise):
# DATABASE_URL=postgres://user:password@localhost:5432/aegisgate?sslmode=require

# For Redis caching (Professional+):
# REDIS_URL=redis://localhost:6379

# =============================================================================
# AI PROVIDERS
# =============================================================================
# Add your API keys here for the providers you want to use
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# COHERE_API_KEY=your-cohere-key
# AZURE_OPENAI_KEY=your-azure-key

# =============================================================================
# COMPLIANCE
# =============================================================================
AEGISGATE_COMPLIANCE_ENABLED=true
AEGISGATE_COMPLIANCE_FRAMEWORKS=owasp

# =============================================================================
# MACHINE LEARNING
# =============================================================================
AEGISGATE_ML_ENABLED=true
AEGISGATE_ML_MODEL_PATH=/var/lib/aegisgate/models

# =============================================================================
# ADMIN
# =============================================================================
AEGISGATE_ADMIN_USER=admin
# AEGISGATE_ADMIN_PASSWORD=change-this-password

# =============================================================================
# DEVELOPMENT OPTIONS
# =============================================================================
# AEGISGATE_DEV_MODE=false
