# .gitignore

# Binaries
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary
*.test

# Output of the go coverage tool
*.out
coverage.out
coverage.html

# Go workspace file
go.work

# Dependency directories
vendor/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment files
.env
.env.local
.env.*.local

# Build artifacts
dist/
build/

# Docker
.docker/

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp

# Database
*.db
*.sqlite
*.sqlite3

# Certificates (keep these secure!)
*.pem
*.key
*.crt
!examples/*.pem

# Test coverage
coverage/
