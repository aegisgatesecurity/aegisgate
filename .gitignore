# ==========================================
# AEGISGATE .GITIGNORE
# Security-critical: Protect sensitive files
# ==========================================

# ----------------------------------------
# BUILD OUTPUT
# ----------------------------------------
aegisgate
aegisgate.exe
*.exe
*.dll
*.so
*.dylib
aegisgate-debug
gencerts
licensegen
padlock
*.test
*.out
*.log
go.work
dist/
build/
bin/

# ----------------------------------------
# CONFIGURATION & SECRETS (CRITICAL)
# ----------------------------------------
config/*.env
!config/*.env.example
config/production*.yml
.mlintel/
.mlintel_config/
ml_config/
configs/*.yml
!configs/*.example.yml
!configs/siem.yaml
.env.local
.env.*.local
.env.backup
.env.production

# ----------------------------------------
# PROPRIETARY / INTERNAL CODE
# ----------------------------------------
cmd/licensegen/
cmd/padlock/
cmd/debug/
cmd/gencerts/
.hooks/
.git/hooks/
scripts/*.ps1
scripts/*.sh

# ----------------------------------------
# DEVELOPMENT ARTIFACTS
# ----------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.tmp
*.temp
*.bak
*.backup
*~
_commit_msg.txt
tag_message.txt
push_fixes.ps1
commit_release.ps1
VERSION

# ----------------------------------------
# TEST & BENCHMARK OUTPUTS
# ----------------------------------------
pkg/**/benchmark_results.txt
tests/**/benchmark*.txt
*_benchmark*.txt
coverage.out
coverage.html
*.cov
tests/integration/fixtures/
tests/integration/aiapifixtures/

# ----------------------------------------
# DEPLOYMENT & INFRASTRUCTURE
# ----------------------------------------
deploy/k8s/*-secret.yaml
deploy/k8s/*-secret.yml
*.tfstate
*.tfstate.*
.terraform/
volumes/

# ----------------------------------------
# SECURITY SCANS & AUDITS
# ----------------------------------------
security_scan_results*
vulnerability_report*
*.sarif

# ----------------------------------------
# EXTERNAL & DEPENDENCIES
# ----------------------------------------
node_modules/
vendor/
packages/
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
env/

# ----------------------------------------
# LICENSE & COMPLIANCE
# ----------------------------------------
*.lic
license.key
licenses/
compliance_evidence/
audit_logs/
