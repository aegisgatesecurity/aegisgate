# ============================================================================
# AegisGate .gitignore
# ============================================================================
# Security Note: Never commit sensitive data, keys, or proprietary information

# ============================================================================
# BUILD OUTPUTS
# ============================================================================
bin/
build/
dist/
*.exe
*.out
*.dll
*.so
*.dylib
coverage_*.out
*.egg-info/

# ============================================================================
# GO
# ============================================================================
vendor/
*.test
coverage.txt
*.sum

# ============================================================================
# IDE & EDITOR
# ============================================================================
.idea/
.vscode/
*.swp
*.swo
*.iml
*.iws
.project
.classpath
.settings/
*.sublime-*

# ============================================================================
# OPERATING SYSTEM
# ============================================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================================================
# ENVIRONMENT & SECRETS
# ============================================================================
.env
.env.local
.env.*.local
.env.production
.env.staging
*.pem
*.key
*.crt
*.pfx
*.p12
*.jks
*. keystore
credentials.json
secrets.yaml
secrets.yml

# ============================================================================
# CERTIFICATES & KEYS
# ============================================================================
certs/
*.key
*.pem
*.crt
*.csr
*.p8
*.pub  # SSH public keys should not be in repo
server.key
server.crt
ca.key
ca.crt

# Key generation and debug tools (local only)
cmd/licensegen/
cmd/padlock/
cmd/debug/
cmd/gencerts/
cmd/secrets/

# ============================================================================
# LOGS & TEMPORARY FILES
# ============================================================================
*.log
logs/
*.tmp
*.temp
*.bak
*.backup
*.swp
~*

# ============================================================================
# DEVELOPMENT MEMORANDA & NOTES
# ============================================================================

# Memory files from AI assistants
MEMORIES/
*_memory.md
*memory.md
memory/
project_memory.md
PROJECT_MEMORY.md
SESSION_MEMORY.md

# Internal notes and planning
internal_notes/
internal/
notes/
planning/
roadmap.md
TODO.md
NOTES.md
CHANGELOG_DEV.md

# Pricing and business information (PRIVATE)
pricing/
pricing.md
pricing.txt
commercial/
business_model/
BUSINESS_MODEL.md

# Archive files
Archive/
archive/
*.zip
*.tar
*.tar.gz
*.tgz

# ============================================================================
# RELEASE & DEPLOYMENT ARTIFACTS
# ============================================================================
RELEASE_NOTES*.md
RELEASE_BODY.md
MIGRATION.md
commit_msg*.txt
tagmsg.txt
gitmsg.txt
cov*.txt
CHANGELOG_AUTOMATED.md

# ============================================================================
# SCRIPTS (local helper scripts)
# ============================================================================
add_*.ps1
*.ps1
deploy_*.sh
setup_*.sh
*.sh.bak

# Security audit scripts (REQUIRED for repository security maintenance)
!REMOVE_KEYS_FROM_GIT_HISTORY.ps1
!REMOVE_ENTERPRISE_PREMIUM.ps1
!REMOVE_KEYS_FROM_GIT_HISTORY.sh
!REMOVE_ENTERPRISE_PREMIUM.sh

# ============================================================================
# TEST ARTIFACTS
# ============================================================================
test_run.zip
*.test.out
test-results/
junit.xml
coverage/

# ============================================================================
# SECURE CUSTOM CONFIGURATIONS
# ============================================================================

# Custom adapter configurations (may contain secrets)
pkg/adapters/certs/
pkg/adapters/custom-certs/
pkg/proxy/certs/ca/
pkg/tls/certs/

# Admin panel credentials
pkg/admin/
admin_config/

# ============================================================================
# EXTERNAL DATA
# ============================================================================
*.db
*.sqlite
*.sqlite3
data/
samples/

# ============================================================================
# CONTRACTS & LEGAL (if in repo)
# ============================================================================
contracts/
*.contract
LICENSE_COMMERCIAL*
