#!/bin/sh
# Padlock Pre-commit Hook
# Runs golangci-lint and go vet before commit

echo "Running pre-commit checks..."

# Check for Go files
GO_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' | head -20)

if [ -z "$GO_FILES" ]; then
    echo "No Go files to check"
    exit 0
fi

echo "Checking Go files: $GO_FILES"

# Run go vet (works on Windows)
echo "Running go vet..."
go vet ./cmd/padlock/... ./pkg/... 2>&1
VET_RESULT=$?

if [ $VET_RESULT -ne 0 ]; then
    echo "FAILED: go vet found issues"
    exit 1
fi

echo "PASSED: All pre-commit checks"
exit 0
